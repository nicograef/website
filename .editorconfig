# EditorConfig – consistent formatting across editors
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# PHP – 4-space convention
[*.php]
indent_size = 4

# Markdown – trailing spaces can be intentional (line breaks)
[*.md]
trim_trailing_whitespace = false
