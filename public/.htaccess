# Custom error pages
ErrorDocument 404 /404.php

# URL Rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Articles routing
    RewriteRule ^articles/?$ /articles.php [L,QSA]
    RewriteRule ^articles/([a-z0-9-]+)/?$ /articles.php?slug=$1 [L,QSA]

    # CV
    RewriteRule ^cv/?$ /cv.php [L]

    # Sitemap
    RewriteRule ^sitemap\.xml$ /sitemap.php [L]

    # Block direct access to .php files — only pretty routes are public
    RewriteCond %{IS_SUBREQ} false
    RewriteCond %{THE_REQUEST} \s/+[^\s]+\.php[\s?]
    RewriteRule \.php$ - [R=404,L]
</IfModule>

# Security: Protect internal folders
<IfModule mod_rewrite.c>
    # Block direct access to content folder
    RewriteRule ^content/ - [F,L]

    # Block direct access to PHP helpers
    RewriteRule ^lib/ - [F,L]

    # Block direct access to templates
    RewriteRule ^templates/ - [F,L]

    # Block direct access to vendor PHP (static assets in vendor still allowed)
    RewriteRule ^vendor/.*\.php$ - [F,L]
</IfModule>

# Security: Prevent direct access to Markdown files
<FilesMatch "\.md$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml application/xml
</IfModule>

<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml application/xml
</IfModule>

# Cache-Control headers for static assets
<IfModule mod_headers.c>
    # Images
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    
    # Fonts
    <FilesMatch "\.(ttf|woff|woff2|eot)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    
    # CSS and JavaScript — safe to cache long/immutable because layout.php
    # appends a content-hash ?v= query (see asset() in lib/render.php), so the
    # URL changes whenever the file does and a stale copy is never reused.
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # HTML files (no cache)
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>
