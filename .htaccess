# Custom error pages
ErrorDocument 404 /404.php

# URL Rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Articles routing
    RewriteRule ^articles/?$ /articles/index.php [L,QSA]
    RewriteRule ^articles/([a-z0-9-]+)/?$ /articles/index.php?slug=$1 [L,QSA]
    
    # Sitemap
    RewriteRule ^sitemap\.xml$ /sitemap.php [L]
</IfModule>

# Security: Protect internal folders
<IfModule mod_rewrite.c>
    # Block direct access to content folder
    RewriteRule ^content/ - [F,L]

    # Block direct access to PHP source folder
    RewriteRule ^src/ - [F,L]

    # Block direct access to vendor folder (except CSS)
    RewriteRule ^vendor/.*\.php$ - [F,L]
</IfModule>

# Security: Prevent direct access to Markdown files
<FilesMatch "\.md$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json
</IfModule>

# Cache-Control headers for static assets
<IfModule mod_headers.c>
    # Images
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    
    # Fonts
    <FilesMatch "\.(ttf|woff|woff2|eot)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    
    # CSS and JavaScript
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    
    # HTML files (no cache)
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>
